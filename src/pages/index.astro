---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchAutocomplete from '../components/SearchAutocomplete.astro';
import DefinitionCard from '../components/DefinitionCard.astro';
import { supabase } from '../lib/supabase';

// Fetch popular definitions
const { data: popularDefinitions } = await supabase
  .from('crossword_definitions')
  .select('slug, definition_he, crossword_solutions(id)')
  .order('search_count', { ascending: false })
  .limit(20);

// Fetch recently added definitions
const { data: recentDefinitions } = await supabase
  .from('crossword_definitions')
  .select('slug, definition_he, crossword_solutions(id)')
  .order('created_at', { ascending: false })
  .limit(20);

// Fetch counts for stats
const { count: definitionCount } = await supabase
  .from('crossword_definitions')
  .select('*', { count: 'exact', head: true });

const { count: solutionCount } = await supabase
  .from('crossword_solutions')
  .select('*', { count: 'exact', head: true });

// Word length ranges
const wordLengths = [2, 3, 4, 5, 6, 7, 8, 9, 10];

// Organization schema
const siteUrl = Astro.site?.toString() || 'https://matzati.co.il';
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'מצאתי',
  url: siteUrl,
  description: 'מאגר פתרונות תשבצים, מילים נרדפות וחרוזים בעברית',
  sameAs: []
};
---

<BaseLayout title="פתרונות תשבצים בעברית | מילים נרדפות וחרוזים" description="מצאתי - מאגר פתרונות תשבצים בעברית. חפש הגדרות, מילים נרדפות, חרוזים ומילים לפי אורך. פותר תשבצים חינם." schema={organizationSchema}>
  <!-- Hero Section -->
  <section class="text-center py-16 md:py-24 relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 start-1/4 w-64 h-64 bg-brand-100 rounded-full blur-3xl opacity-50"></div>
    <div class="absolute bottom-0 end-1/4 w-48 h-48 bg-accent-400 rounded-full blur-3xl opacity-20"></div>

    <div class="relative z-10">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-text">
        מצאתי - פתרונות תשבצים בעברית
      </h1>
      <p class="text-xl md:text-2xl text-muted mb-8 max-w-2xl mx-auto">
        חפש פתרונות להגדרות, מילים נרדפות, חרוזים ועוד
      </p>
      <SearchAutocomplete />
      <p class="text-sm text-muted mt-6">
        <span class="font-semibold text-brand-600">{definitionCount?.toLocaleString('he-IL')}</span> הגדרות
        <span class="mx-2">•</span>
        <span class="font-semibold text-brand-600">{solutionCount?.toLocaleString('he-IL')}</span> פתרונות
      </p>
    </div>
  </section>

  <!-- Popular Definitions -->
  {popularDefinitions && popularDefinitions.length > 0 && (
    <section class="py-12 md:py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text">הגדרות פופולריות</h2>
        <a href="/categories" class="text-brand-600 hover:text-brand-700 font-medium">כל הקטגוריות ←</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4">
        {popularDefinitions.map((def) => (
          <DefinitionCard
            slug={def.slug}
            definition={def.definition_he}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Recently Added -->
  {recentDefinitions && recentDefinitions.length > 0 && (
    <section class="py-12 md:py-16 bg-surface border-y border-border">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text">נוספו לאחרונה</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4">
        {recentDefinitions.map((def) => (
          <DefinitionCard
            slug={def.slug}
            definition={def.definition_he}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Words by Length -->
  <section class="py-12 md:py-16 bg-brand-50 -mx-4 px-4 md:-mx-8 md:px-8">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-text">מילים לפי אורך</h2>
      <div class="grid grid-cols-3 md:grid-cols-5 lg:grid-cols-9 gap-3 md:gap-4">
        {wordLengths.map((n) => (
          <a
            href={`/length/${n}`}
            class="group p-4 md:p-5 bg-surface border border-border rounded-xl text-center hover:border-brand-400 hover:shadow-lg hover:shadow-brand-500/10 transition-all"
          >
            <span class="text-3xl md:text-4xl font-bold text-brand-600 group-hover:text-brand-700 transition-colors">{n}</span>
            <span class="block text-sm text-muted mt-1">אותיות</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Alphabet Navigation -->
  <section class="py-12 md:py-16">
    <h2 class="text-2xl md:text-3xl font-bold mb-8 text-text">חיפוש לפי אות</h2>
    <div class="flex flex-wrap gap-2 justify-center">
      {['א','ב','ג','ד','ה','ו','ז','ח','ט','י','כ','ל','מ','נ','ס','ע','פ','צ','ק','ר','ש','ת'].map((letter) => (
        <a
          href={`/letter/${letter}`}
          class="w-11 h-11 flex items-center justify-center bg-surface border border-border rounded-lg text-lg font-semibold text-text hover:bg-brand-500 hover:text-white hover:border-brand-500 transition-all"
        >
          {letter}
        </a>
      ))}
    </div>
  </section>

  <!-- Tools -->
  <section class="py-12 md:py-16 bg-brand-50 -mx-4 px-4 md:-mx-8 md:px-8">
    <h2 class="text-2xl md:text-3xl font-bold mb-8 text-text">כלים</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      <a href="/solver" class="group p-6 md:p-8 bg-surface border border-border rounded-xl text-center hover:border-brand-400 hover:shadow-lg hover:shadow-brand-500/10 transition-all">
        <span class="text-4xl md:text-5xl block mb-3">&#129513;</span>
        <span class="block text-lg font-semibold text-text group-hover:text-brand-700 transition-colors">פותר תשבצים</span>
        <span class="block text-sm text-muted mt-1">חיפוש לפי הגדרה או תבנית</span>
      </a>
      <a href="/categories" class="group p-6 md:p-8 bg-surface border border-border rounded-xl text-center hover:border-brand-400 hover:shadow-lg hover:shadow-brand-500/10 transition-all">
        <span class="text-4xl md:text-5xl block mb-3">&#128218;</span>
        <span class="block text-lg font-semibold text-text group-hover:text-brand-700 transition-colors">קטגוריות</span>
        <span class="block text-sm text-muted mt-1">גיאוגרפיה, טבע, היסטוריה ועוד</span>
      </a>
      <a href="/synonyms" class="group p-6 md:p-8 bg-surface border border-border rounded-xl text-center hover:border-brand-400 hover:shadow-lg hover:shadow-brand-500/10 transition-all">
        <span class="text-4xl md:text-5xl block mb-3">&#127925;</span>
        <span class="block text-lg font-semibold text-text group-hover:text-brand-700 transition-colors">מילים נרדפות</span>
        <span class="block text-sm text-muted mt-1">מצא מילה נרדפת</span>
      </a>
      <a href="/rhymes" class="group p-6 md:p-8 bg-surface border border-border rounded-xl text-center hover:border-brand-400 hover:shadow-lg hover:shadow-brand-500/10 transition-all">
        <span class="text-4xl md:text-5xl block mb-3">&#127919;</span>
        <span class="block text-lg font-semibold text-text group-hover:text-brand-700 transition-colors">חרוזים</span>
        <span class="block text-sm text-muted mt-1">מצא חרוז למילה</span>
      </a>
    </div>
  </section>
</BaseLayout>
