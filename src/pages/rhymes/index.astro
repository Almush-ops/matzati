---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Popular words - curated from DB top rhyme counts
const popularWords = [
  { word: 'ארוחה', total: 129 },
  { word: 'פרי', total: 125 },
  { word: 'שמן', total: 125 },
  { word: 'רותם', total: 123 },
  { word: 'שוטה', total: 119 },
  { word: 'כיפה', total: 113 },
  { word: 'בנין', total: 114 },
  { word: 'דבורה', total: 111 },
  { word: 'איתן', total: 105 },
  { word: 'אדמה', total: 105 },
  { word: 'גרם', total: 106 },
  { word: 'מימן', total: 107 },
  { word: 'סובלני', total: 103 },
  { word: 'בית', total: 66 },
  { word: 'אהבה', total: 38 },
  { word: 'אש', total: 19 },
];

// Sample rhyme pairs
const samplePairs = [
  { word: 'אהבה', rhymes: ['כתובה', 'תשובה', 'מרובה'] },
  { word: 'לב', rhymes: ['זהב', 'כאב'] },
  { word: 'שלום', rhymes: ['חלום'] },
  { word: 'בית', rhymes: ['ריבית', 'עלטה', 'החלטה'] },
  { word: 'אש', rhymes: ['רועש', 'גועש', 'נואש'] },
  { word: 'ארוחה', rhymes: ['מנוחה', 'פתוחה', 'שלוחה'] },
];

// Hebrew letters for the filter
const hebrewLetters = 'אבגדהוזחטיכלמנסעפצקרשת'.split('');
---

<BaseLayout title="חרוזים בעברית | מילון חרוזים לשירים וברכות" description="מילון חרוזים בעברית - מצא חרוזים מלאים וחלקיים לכל מילה. מאגר של 40,000+ חרוזים ל-1,100+ מילים. מושלם לכתיבת שירים, ברכות וטקסטים יצירתיים.">
  <section class="text-center py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-bold mb-3 text-text">חרוזים בעברית</h1>
    <p class="text-muted mb-2">מאגר של 40,000+ חרוזים ל-1,100+ מילים</p>
    <p class="text-sm text-muted mb-8">מצא חרוז לכל מילה - לשירים, ברכות ועוד</p>

    <form id="search-form" class="max-w-xl mx-auto mb-8">
      <div class="relative">
        <input
          type="search"
          id="search-input"
          placeholder="הקלד מילה לחיפוש חרוזים..."
          class="w-full px-6 py-4 text-lg bg-surface border-2 border-border rounded-full focus:border-brand-500 focus:ring-4 focus:ring-brand-100 outline-none transition-all"
        />
        <button
          type="submit"
          class="absolute left-2 top-1/2 -translate-y-1/2 bg-accent-500 text-gray-900 px-6 py-3 rounded-full font-semibold hover:bg-accent-600 transition-colors shadow-md"
        >
          חפש
        </button>
      </div>
    </form>

    <!-- Stats -->
    <div class="flex justify-center gap-8 md:gap-12">
      <div class="text-center">
        <span class="text-2xl md:text-3xl font-bold text-brand-600">1,176</span>
        <span class="block text-sm text-muted">מילים</span>
      </div>
      <div class="text-center">
        <span class="text-2xl md:text-3xl font-bold text-brand-600">40,508</span>
        <span class="block text-sm text-muted">חרוזים</span>
      </div>
      <div class="text-center">
        <span class="text-2xl md:text-3xl font-bold text-brand-600">2</span>
        <span class="block text-sm text-muted">סוגים: מלא וחלקי</span>
      </div>
    </div>
  </section>

  <!-- Alphabetical Index -->
  <section class="py-8 md:py-12">
    <h2 class="text-2xl font-bold mb-6 text-text">חיפוש לפי אות</h2>
    <div id="letter-filter" class="flex flex-wrap gap-2 justify-center">
      {hebrewLetters.map((letter) => (
        <button
          type="button"
          data-letter={letter}
          class="letter-btn w-12 h-12 flex items-center justify-center bg-surface border border-border rounded-lg text-xl font-bold hover:border-brand-400 hover:bg-brand-50 hover:text-brand-600 transition-all cursor-pointer"
        >
          {letter}
        </button>
      ))}
    </div>
  </section>

  <!-- Results container -->
  <section id="results-section" class="py-8 md:py-12 hidden">
    <div class="flex items-center justify-between mb-6">
      <h2 id="results-title" class="text-xl font-semibold text-text"></h2>
      <button id="clear-filter" class="text-brand-600 hover:text-brand-700 underline text-sm">
        נקה סינון
      </button>
    </div>
    <div id="results-container"></div>
  </section>

  <!-- Loading state -->
  <div id="loading" class="hidden py-12 text-center">
    <div class="inline-block w-8 h-8 border-4 border-brand-200 border-t-brand-500 rounded-full animate-spin"></div>
    <p class="mt-4 text-muted">מחפש...</p>
  </div>

  <!-- Popular Rhyme Words (sorted by count) -->
  <section id="popular-section" class="py-8 md:py-12">
    <h2 class="text-2xl font-bold mb-6 text-text">מילים פופולריות</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">
      {popularWords.map(({ word, total }) => (
        <a
          href={`/rhymes/${word}`}
          class="group p-4 bg-surface border border-border rounded-lg hover:border-brand-300 hover:shadow-md hover:shadow-brand-500/10 transition-all flex flex-col items-center gap-1"
        >
          <span class="group-hover:text-brand-600 transition-colors font-medium">{word}</span>
          <span class="text-xs text-muted">{total} חרוזים</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Sample Rhyme Pairs -->
  <section class="py-8 md:py-12">
    <h2 class="text-2xl font-bold mb-6 text-text">דוגמאות לחרוזים</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {samplePairs.map(({ word, rhymes }) => (
        <a href={`/rhymes/${word}`} class="group p-5 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-md transition-all">
          <span class="text-lg font-bold text-brand-600 group-hover:text-brand-700 transition-colors">{word}</span>
          <div class="flex flex-wrap gap-2 mt-3">
            {rhymes.map((r) => (
              <span class="px-3 py-1 bg-brand-50 text-brand-600 rounded-full text-sm">{r}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Rhyme Types -->
  <section class="py-8 md:py-12 bg-brand-50 border border-brand-100 rounded-xl p-6 md:p-8">
    <h2 class="text-xl font-semibold mb-6 text-text">סוגי חרוזים</h2>
    <div class="grid md:grid-cols-3 gap-4">
      <div class="p-5 bg-surface rounded-xl border border-brand-100">
        <h3 class="font-semibold mb-2 text-brand-700">חרוז מלא</h3>
        <p class="text-sm text-muted">מילים עם סיומת זהה (אהבה - תשובה)</p>
      </div>
      <div class="p-5 bg-surface rounded-xl border border-brand-100">
        <h3 class="font-semibold mb-2 text-brand-700">חרוז חלקי</h3>
        <p class="text-sm text-muted">מילים עם צליל דומה (שלום - יום)</p>
      </div>
      <div class="p-5 bg-surface rounded-xl border border-brand-100">
        <h3 class="font-semibold mb-2 text-brand-700">אסונאנס</h3>
        <p class="text-sm text-muted">חזרה על תנועות דומות</p>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-8 md:py-12">
    <h2 class="text-2xl font-bold mb-6 text-text">מתי משתמשים בחרוזים?</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="p-5 bg-surface border border-border rounded-xl">
        <h3 class="font-semibold mb-2 text-text">שירים</h3>
        <p class="text-sm text-muted">חרוזים לשירים ופזמונים</p>
      </div>
      <div class="p-5 bg-surface border border-border rounded-xl">
        <h3 class="font-semibold mb-2 text-text">ברכות</h3>
        <p class="text-sm text-muted">ברכות מחורזות לימי הולדת ואירועים</p>
      </div>
      <div class="p-5 bg-surface border border-border rounded-xl">
        <h3 class="font-semibold mb-2 text-text">ראפ</h3>
        <p class="text-sm text-muted">חרוזים לכתיבת ראפ בעברית</p>
      </div>
      <div class="p-5 bg-surface border border-border rounded-xl">
        <h3 class="font-semibold mb-2 text-text">משחקי מילים</h3>
        <p class="text-sm text-muted">חרוזים לחידונים ומשחקים</p>
      </div>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="py-8 md:py-12">
    <h2 class="text-2xl font-bold mb-6 text-text">כלים נוספים</h2>
    <div class="grid md:grid-cols-3 gap-4">
      <a href="/solver" class="group p-6 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-semibold text-lg mb-2 group-hover:text-brand-600 transition-colors">פותר תשבצים</h3>
        <p class="text-sm text-muted">חפש פתרונות לפי הגדרה או תבנית אותיות</p>
      </a>
      <a href="/synonyms" class="group p-6 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-semibold text-lg mb-2 group-hover:text-brand-600 transition-colors">מילים נרדפות</h3>
        <p class="text-sm text-muted">מצא סינונימים לכל מילה בעברית</p>
      </a>
      <a href="/words" class="group p-6 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-semibold text-lg mb-2 group-hover:text-brand-600 transition-colors">מילים לפי אורך</h3>
        <p class="text-sm text-muted">רשימות מילים לפי מספר אותיות</p>
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const supabase = createClient(supabaseUrl, supabaseAnonKey);

  const form = document.getElementById('search-form') as HTMLFormElement;
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsSection = document.getElementById('results-section')!;
  const resultsTitle = document.getElementById('results-title')!;
  const resultsContainer = document.getElementById('results-container')!;
  const popularSection = document.getElementById('popular-section')!;
  const loading = document.getElementById('loading')!;
  const clearBtn = document.getElementById('clear-filter')!;
  const letterBtns = document.querySelectorAll('.letter-btn');

  function showResults() {
    resultsSection.classList.remove('hidden');
    popularSection.classList.add('hidden');
  }

  function hideResults() {
    resultsSection.classList.add('hidden');
    popularSection.classList.remove('hidden');
    letterBtns.forEach(btn => {
      btn.classList.remove('bg-brand-500', 'text-white', 'border-brand-500');
      btn.classList.add('bg-surface', 'border-border', 'text-text');
    });
  }

  async function searchByQuery(query: string) {
    if (!query.trim()) return;

    const url = new URL(window.location.href);
    url.searchParams.delete('letter');
    url.searchParams.set('q', query);
    window.history.pushState({}, '', url);

    loading.classList.remove('hidden');
    popularSection.classList.add('hidden');
    resultsSection.classList.add('hidden');

    try {
      const { data: results } = await supabase
        .from('rhymes')
        .select('word, rhyme, rhyme_type')
        .or(`word.ilike.%${query}%,rhyme.ilike.%${query}%`)
        .limit(50);

      const uniqueWords = [...new Set(results?.map(r => r.word) || [])];

      loading.classList.add('hidden');
      showResults();
      resultsTitle.textContent = `תוצאות עבור "${query}" (${uniqueWords.length} נמצאו)`;

      if (uniqueWords.length > 0) {
        resultsContainer.innerHTML = `
          <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">
            ${uniqueWords.map((word: string) => `
              <a href="/rhymes/${encodeURIComponent(word)}"
                 class="group p-4 bg-surface border border-border rounded-lg text-center hover:border-brand-300 hover:shadow-md transition-all">
                <span class="group-hover:text-brand-600 transition-colors">${word}</span>
              </a>
            `).join('')}
          </div>
        `;
      } else {
        resultsContainer.innerHTML = `
          <div class="bg-brand-50 rounded-xl p-8 text-center border border-brand-100">
            <p class="text-muted">לא נמצאו חרוזים עבור "${query}"</p>
            <p class="text-sm mt-2 text-muted">נסה מילה אחרת</p>
          </div>
        `;
      }
    } catch (error) {
      console.error('Search error:', error);
      loading.classList.add('hidden');
      showResults();
      resultsTitle.textContent = 'שגיאה בחיפוש';
      resultsContainer.innerHTML = `
        <div class="bg-red-50 rounded-xl p-8 text-center border border-red-100">
          <p class="text-red-600">אירעה שגיאה בחיפוש. נסה שוב.</p>
        </div>
      `;
    }
  }

  async function filterByLetter(letter: string) {
    const url = new URL(window.location.href);
    url.searchParams.delete('q');
    url.searchParams.set('letter', letter);
    window.history.pushState({}, '', url);

    letterBtns.forEach(btn => {
      if (btn.getAttribute('data-letter') === letter) {
        btn.classList.remove('bg-surface', 'border-border', 'text-text');
        btn.classList.add('bg-brand-500', 'text-white', 'border-brand-500');
      } else {
        btn.classList.remove('bg-brand-500', 'text-white', 'border-brand-500');
        btn.classList.add('bg-surface', 'border-border', 'text-text');
      }
    });

    loading.classList.remove('hidden');
    popularSection.classList.add('hidden');
    resultsSection.classList.add('hidden');

    try {
      const { data: results } = await supabase
        .from('rhymes')
        .select('word')
        .ilike('word', `${letter}%`)
        .limit(500);

      const uniqueWords = [...new Set(results?.map(r => r.word) || [])];

      loading.classList.add('hidden');
      showResults();
      resultsTitle.textContent = `מילים המתחילות ב"${letter}" (${uniqueWords.length} נמצאו)`;

      if (uniqueWords.length > 0) {
        resultsContainer.innerHTML = `
          <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">
            ${uniqueWords.map((word: string) => `
              <a href="/rhymes/${encodeURIComponent(word)}"
                 class="group p-4 bg-surface border border-border rounded-lg text-center hover:border-brand-300 hover:shadow-md transition-all">
                <span class="group-hover:text-brand-600 transition-colors">${word}</span>
              </a>
            `).join('')}
          </div>
        `;
      } else {
        resultsContainer.innerHTML = `
          <div class="bg-brand-50 rounded-xl p-8 text-center border border-brand-100">
            <p class="text-muted">לא נמצאו מילים המתחילות ב"${letter}"</p>
          </div>
        `;
      }
    } catch (error) {
      console.error('Filter error:', error);
      loading.classList.add('hidden');
      showResults();
      resultsTitle.textContent = 'שגיאה בסינון';
      resultsContainer.innerHTML = `
        <div class="bg-red-50 rounded-xl p-8 text-center border border-red-100">
          <p class="text-red-600">אירעה שגיאה. נסה שוב.</p>
        </div>
      `;
    }
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    searchByQuery(input.value);
  });

  letterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const letter = btn.getAttribute('data-letter');
      if (letter) filterByLetter(letter);
    });
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    hideResults();
    window.history.pushState({}, '', '/rhymes');
  });

  const urlParams = new URLSearchParams(window.location.search);
  const initialQuery = urlParams.get('q');
  const initialLetter = urlParams.get('letter');

  if (initialQuery) {
    input.value = initialQuery;
    searchByQuery(initialQuery);
  } else if (initialLetter) {
    filterByLetter(initialLetter);
  }
</script>
