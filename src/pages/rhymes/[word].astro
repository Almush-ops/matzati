---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  const { data: rhymes } = await supabase
    .from('rhymes')
    .select('word');

  const uniqueWords = [...new Set(rhymes?.map(r => r.word) || [])];

  return uniqueWords.map((word) => ({
    params: { word },
  }));
}

const { word } = Astro.params;

// Fetch rhymes for this word
const { data: rhymes } = await supabase
  .from('rhymes')
  .select('*')
  .eq('word', word);

// Group by rhyme type
const fullRhymes = rhymes?.filter(r => r.rhyme_type === 'full') || [];
const partialRhymes = rhymes?.filter(r => r.rhyme_type === 'partial') || [];

const pageTitle = `חרוזים ל"${word}"`;
const pageDescription = `${rhymes?.length || 0} חרוזים למילה "${word}" בעברית`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article>
    <nav class="text-sm text-text-muted mb-4">
      <a href="/" class="hover:text-primary">ראשי</a>
      <span class="mx-2">/</span>
      <a href="/rhymes" class="hover:text-primary">חרוזים</a>
      <span class="mx-2">/</span>
      <span class="text-text">{word}</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold mb-2">
      חרוזים ל"{word}"
    </h1>
    <p class="text-text-muted mb-8">
      {rhymes?.length || 0} חרוזים נמצאו
    </p>

    {fullRhymes.length > 0 && (
      <section class="bg-surface border border-gray-200 rounded-lg p-6 mb-6">
        <h2 class="text-xl font-semibold mb-4">חרוזים מלאים</h2>
        <div class="flex flex-wrap gap-3">
          {fullRhymes.map((r) => (
            <a
              href={`/rhymes/${r.rhyme}`}
              class="px-4 py-2 bg-green-500/10 text-green-700 rounded-full hover:bg-green-500/20 transition-all"
            >
              {r.rhyme}
            </a>
          ))}
        </div>
      </section>
    )}

    {partialRhymes.length > 0 && (
      <section class="bg-surface border border-gray-200 rounded-lg p-6">
        <h2 class="text-xl font-semibold mb-4">חרוזים חלקיים</h2>
        <div class="flex flex-wrap gap-3">
          {partialRhymes.map((r) => (
            <a
              href={`/rhymes/${r.rhyme}`}
              class="px-4 py-2 bg-gray-100 rounded-full hover:bg-gray-200 transition-all"
            >
              {r.rhyme}
            </a>
          ))}
        </div>
      </section>
    )}

    {(!rhymes || rhymes.length === 0) && (
      <div class="bg-gray-50 rounded-lg p-8 text-center">
        <p class="text-text-muted">לא נמצאו חרוזים למילה זו.</p>
      </div>
    )}
  </article>
</BaseLayout>
