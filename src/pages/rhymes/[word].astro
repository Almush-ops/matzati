---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchAll } from '../../lib/fetchAll';

export async function getStaticPaths() {
  // Bulk fetch ALL rhymes
  const allRhymes = await fetchAll('rhymes', 'word, rhyme, rhyme_type');
  console.log(`[rhymes] Fetched ${allRhymes.length} rhyme rows`);

  // Group by word
  const rhymesByWord = new Map<string, { full: string[]; partial: string[] }>();
  for (const r of allRhymes) {
    if (!rhymesByWord.has(r.word)) rhymesByWord.set(r.word, { full: [], partial: [] });
    const group = rhymesByWord.get(r.word)!;
    if (r.rhyme_type === 'full') group.full.push(r.rhyme);
    else group.partial.push(r.rhyme);
  }

  const uniqueWords = [...rhymesByWord.keys()];
  console.log(`[rhymes] ${uniqueWords.length} unique words`);

  return uniqueWords.map((word) => {
    const data = rhymesByWord.get(word)!;
    return {
      params: { word },
      props: { fullRhymes: data.full, partialRhymes: data.partial },
    };
  });
}

const { word } = Astro.params;
const { fullRhymes, partialRhymes } = Astro.props;
const totalRhymes = (fullRhymes?.length || 0) + (partialRhymes?.length || 0);

const pageTitle = `חרוזים ל"${word}" | מילון חרוזים בעברית`;
const pageDescription = `${totalRhymes} חרוזים למילה "${word}". חרוזים מלאים וחלקיים לשירים, ברכות וכתיבה יצירתית.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article>
    <nav class="text-sm text-muted mb-6">
      <a href="/" class="hover:text-brand-600 transition-colors">ראשי</a>
      <span class="mx-2 text-border">←</span>
      <a href="/rhymes" class="hover:text-brand-600 transition-colors">חרוזים</a>
      <span class="mx-2 text-border">←</span>
      <span class="text-text">{word}</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold mb-3 text-text">
      חרוזים ל"{word}"
    </h1>
    <p class="text-muted mb-8">
      {totalRhymes} חרוזים נמצאו
    </p>

    {fullRhymes && fullRhymes.length > 0 && (
      <section class="bg-surface border border-border rounded-xl p-6 mb-6">
        <h2 class="text-xl font-semibold mb-4 text-text">חרוזים מלאים</h2>
        <div class="flex flex-wrap gap-3">
          {fullRhymes.map((r: string) => (
            <a
              href={`/rhymes/${r}`}
              class="px-4 py-2 bg-brand-100 text-brand-700 rounded-full hover:bg-brand-200 transition-all font-medium"
            >
              {r}
            </a>
          ))}
        </div>
      </section>
    )}

    {partialRhymes && partialRhymes.length > 0 && (
      <section class="bg-surface border border-border rounded-xl p-6">
        <h2 class="text-xl font-semibold mb-4 text-text">חרוזים חלקיים</h2>
        <div class="flex flex-wrap gap-3">
          {partialRhymes.map((r: string) => (
            <a
              href={`/rhymes/${r}`}
              class="px-4 py-2 bg-brand-50 text-brand-600 border border-brand-200 rounded-full hover:bg-brand-100 transition-all"
            >
              {r}
            </a>
          ))}
        </div>
      </section>
    )}

    {totalRhymes === 0 && (
      <div class="bg-brand-50 border border-brand-100 rounded-xl p-8 text-center">
        <p class="text-muted">לא נמצאו חרוזים למילה זו.</p>
      </div>
    )}
  </article>
</BaseLayout>
