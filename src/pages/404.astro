---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="העמוד לא נמצא | מצאתי" description="העמוד שחיפשת לא נמצא. חזור לעמוד הראשי וחפש הגדרות תשבץ." noindex={true}>
  <div class="text-center py-16 md:py-24">
    <h1 class="text-6xl md:text-8xl font-bold text-brand-200 mb-4">404</h1>
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">העמוד לא נמצא</h2>
    <p class="text-muted mb-8 max-w-md mx-auto">
      מצטערים, העמוד שחיפשת לא קיים או שהקישור שגוי.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/"
        class="inline-flex items-center justify-center px-6 py-3 bg-brand-500 text-white rounded-full font-semibold hover:bg-brand-600 transition-colors"
      >
        חזרה לעמוד הראשי
      </a>
      <a
        href="/solver"
        class="inline-flex items-center justify-center px-6 py-3 bg-surface border border-border text-text rounded-full font-semibold hover:border-brand-300 transition-colors"
      >
        פותר תשבצים
      </a>
    </div>

    <div class="mt-12 p-6 bg-brand-50 border border-brand-100 rounded-xl max-w-lg mx-auto">
      <h3 class="font-semibold text-text mb-3">אולי חיפשת:</h3>
      <ul class="space-y-2 text-muted">
        <li><a href="/solver" class="text-brand-600 hover:underline">פותר תשבצים</a> - חיפוש לפי הגדרה</li>
        <li><a href="/synonyms" class="text-brand-600 hover:underline">מילים נרדפות</a> - מצא מילה נרדפת</li>
        <li><a href="/rhymes" class="text-brand-600 hover:underline">חרוזים</a> - מצא חרוז למילה</li>
        <li><a href="/words/5-letters" class="text-brand-600 hover:underline">מילים בנות 5 אותיות</a> - לוורדל</li>
      </ul>
    </div>
  </div>
</BaseLayout>
