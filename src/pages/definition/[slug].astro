---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchAutocomplete from '../../components/SearchAutocomplete.astro';
import { fetchAll } from '../../lib/fetchAll';

export async function getStaticPaths() {
  // Bulk fetch ALL definitions
  const allDefs = await fetchAll('crossword_definitions', 'id, slug, definition_he, category');
  console.log(`[getStaticPaths] Fetched ${allDefs.length} definitions`);

  // Bulk fetch ALL solutions
  const allSols = await fetchAll('crossword_solutions', 'definition_id, solution, letter_count, explanation');
  console.log(`[getStaticPaths] Fetched ${allSols.length} solutions`);

  // Group solutions by definition_id
  const solsByDefId = new Map<string, any[]>();
  for (const sol of allSols) {
    if (!solsByDefId.has(sol.definition_id)) solsByDefId.set(sol.definition_id, []);
    solsByDefId.get(sol.definition_id)!.push(sol);
  }

  // Group definitions by category for "related"
  const defsByCat = new Map<string, any[]>();
  for (const def of allDefs) {
    if (def.category) {
      if (!defsByCat.has(def.category)) defsByCat.set(def.category, []);
      defsByCat.get(def.category)!.push({ slug: def.slug, definition_he: def.definition_he });
    }
  }

  return allDefs.map((def) => {
    const solutions = (solsByDefId.get(def.id) || []).sort((a: any, b: any) => a.letter_count - b.letter_count);
    const catDefs = defsByCat.get(def.category) || [];
    const relatedDefs = catDefs.filter((d: any) => d.slug !== def.slug).slice(0, 8);

    return {
      params: { slug: def.slug },
      props: { definition: def, solutions, relatedDefs },
    };
  });
}

const { definition, solutions, relatedDefs } = Astro.props;

// Group solutions by letter count
const solutionsByLength = solutions?.reduce((acc: any, sol: any) => {
  const key = sol.letter_count;
  if (!acc[key]) acc[key] = [];
  acc[key].push(sol);
  return acc;
}, {} as Record<number, any[]>) || {};

const pageTitle = `${definition?.definition_he} - פתרון תשבץ`;
const pageDescription = `${solutions?.length || 0} פתרונות להגדרה "${definition?.definition_he}" בתשבץ. צפה בפתרונות לפי מספר אותיות ומצא את המילה המתאימה.`;

// Schema markup
const siteUrl = Astro.site?.toString() || 'https://matzati.co.il';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ראשי', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'הגדרות', item: `${siteUrl}/solver` },
    { '@type': 'ListItem', position: 3, name: definition?.definition_he }
  ]
};

const definitionSchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: definition?.definition_he,
  description: pageDescription,
  inLanguage: 'he',
  hasDefinedTerm: solutions?.slice(0, 10).map((sol: any) => ({
    '@type': 'DefinedTerm',
    name: sol.solution,
    description: sol.explanation || `פתרון של ${sol.letter_count} אותיות להגדרה "${definition?.definition_he}"`
  })) || []
};

const pageSchema = [breadcrumbSchema, definitionSchema];
---

<BaseLayout title={pageTitle} description={pageDescription} schema={pageSchema}>
  <article>
    <!-- Breadcrumb -->
    <nav class="text-sm text-muted mb-6">
      <a href="/" class="hover:text-brand-600 transition-colors">ראשי</a>
      <span class="mx-2 text-border">←</span>
      <span>הגדרות</span>
      <span class="mx-2 text-border">←</span>
      <span class="text-text">{definition?.definition_he}</span>
    </nav>

    <!-- Title -->
    <h1 class="text-3xl md:text-4xl font-bold mb-3 text-text">
      {definition?.definition_he}
    </h1>
    <p class="text-muted mb-8">
      {solutions?.length || 0} פתרונות נמצאו להגדרה זו
    </p>

    <!-- Solutions by Length -->
    {Object.keys(solutionsByLength).length > 0 ? (
      <div class="space-y-6">
        {Object.entries(solutionsByLength)
          .sort(([a], [b]) => Number(a) - Number(b))
          .map(([length, sols]) => (
            <section class="bg-surface border border-border rounded-xl p-6">
              <h2 class="text-xl font-semibold mb-4 flex items-center gap-3 text-text">
                <span class="bg-brand-500 text-white w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold">
                  {length}
                </span>
                פתרונות של {length} אותיות
              </h2>
              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                {(sols as any[]).map((sol) => (
                  <div class="p-4 bg-brand-50 border border-brand-100 rounded-lg">
                    <span class="font-semibold text-lg text-brand-700">{sol.solution}</span>
                    {sol.explanation && (
                      <p class="text-sm text-muted mt-1">{sol.explanation}</p>
                    )}
                  </div>
                ))}
              </div>
            </section>
          ))}
      </div>
    ) : (
      <div class="bg-brand-50 border border-brand-100 rounded-xl p-8 text-center">
        <p class="text-muted">לא נמצאו פתרונות להגדרה זו עדיין.</p>
      </div>
    )}

    <!-- Related Definitions -->
    {relatedDefs && relatedDefs.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-bold mb-6 text-text">הגדרות קשורות</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {relatedDefs.map((def: any) => (
            <a
              href={`/definition/${def.slug}`}
              class="group p-4 bg-surface border border-border rounded-lg hover:border-brand-300 hover:shadow-md hover:shadow-brand-500/10 transition-all"
            >
              <span class="group-hover:text-brand-600 transition-colors">{def.definition_he}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Search CTA -->
    <section class="mt-12 bg-brand-50 border border-brand-100 rounded-xl p-8 text-center">
      <h2 class="text-xl font-semibold mb-4 text-text">לא מצאת את מה שחיפשת?</h2>
      <SearchAutocomplete placeholder="חפש הגדרה אחרת..." />
    </section>
  </article>
</BaseLayout>
