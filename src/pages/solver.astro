---
import BaseLayout from '../layouts/BaseLayout.astro';
import { supabase } from '../lib/supabase';

// Get popular definitions at build time
const { data: popularDefs } = await supabase
  .from('crossword_definitions')
  .select('slug, definition_he')
  .not('definition_he', 'ilike', 'חרוז ל%')
  .not('definition_he', 'ilike', 'מילה נרדפת ל%')
  .order('search_count', { ascending: false })
  .limit(24);

// Categories with English slugs matching /category/[slug] pages
const categories = [
  { name: 'ידע כללי', slug: 'general', count: 2311 },
  { name: 'שפה ומילים', slug: 'language', count: 2290 },
  { name: 'אוכל ומשקאות', slug: 'food', count: 1174 },
  { name: 'מדעים', slug: 'science', count: 649 },
  { name: 'ספורט', slug: 'sports', count: 644 },
  { name: 'גיאוגרפיה', slug: 'geography', count: 506 },
  { name: 'בעלי חיים', slug: 'animals', count: 377 },
  { name: 'היסטוריה ויהדות', slug: 'history', count: 343 },
  { name: 'אנשים', slug: 'people', count: 296 },
  { name: 'טבע', slug: 'nature', count: 265 },
  { name: 'מוזיקה', slug: 'music', count: 104 },
  { name: 'ספרות', slug: 'literature', count: 69 },
];
---

<BaseLayout title="פותר תשבצים אוטומטי בעברית | חיפוש לפי הגדרה" description="פותר תשבצים חינם - הקלד הגדרה או תבנית אותיות ומצא את הפתרון. מאגר של למעלה מ-88,000 פתרונות ו-10,000 הגדרות לתשבצים בעברית.">
  <!-- Hero Search -->
  <section class="text-center py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-bold mb-3 text-text">פותר תשבצים אוטומטי</h1>
    <p class="text-muted mb-2">המאגר הגדול בישראל לפתרון תשבצים</p>
    <p class="text-sm text-muted mb-4">הקלד הגדרה או תבנית (לדוגמה: א?ב?ה)</p>

    <!-- Stats -->
    <div class="flex justify-center gap-6 md:gap-10 mb-8">
      <div class="text-center">
        <span class="text-xl md:text-2xl font-bold text-brand-600">88,134</span>
        <span class="block text-xs text-muted">פתרונות</span>
      </div>
      <div class="text-center">
        <span class="text-xl md:text-2xl font-bold text-brand-600">10,003</span>
        <span class="block text-xs text-muted">הגדרות</span>
      </div>
      <div class="text-center">
        <span class="text-xl md:text-2xl font-bold text-brand-600">15</span>
        <span class="block text-xs text-muted">קטגוריות</span>
      </div>
    </div>

    <form id="search-form" class="max-w-2xl mx-auto mb-6">
      <div class="relative">
        <input
          type="search"
          id="search-input"
          placeholder="הקלד הגדרה..."
          class="w-full px-6 py-4 text-lg bg-surface border-2 border-border rounded-full focus:border-brand-500 focus:ring-4 focus:ring-brand-100 outline-none transition-all"
        />
        <button
          type="submit"
          class="absolute left-2 top-1/2 -translate-y-1/2 bg-accent-500 text-gray-900 px-6 py-3 rounded-full font-semibold hover:bg-accent-600 transition-colors shadow-md"
        >
          חפש
        </button>
      </div>
    </form>

    <!-- Quick letter count filter -->
    <div class="flex flex-wrap gap-2 justify-center">
      <span class="text-sm text-muted self-center">סנן לפי אותיות:</span>
      {[2, 3, 4, 5, 6, 7, 8].map(n => (
        <button
          type="button"
          data-letters={n}
          class="letter-count-btn px-3 py-1 bg-surface border border-border rounded-full text-sm hover:border-brand-400 hover:bg-brand-50 transition-all cursor-pointer"
        >
          {n} אותיות
        </button>
      ))}
    </div>
  </section>

  <!-- Results container -->
  <section id="results-section" class="py-8 md:py-12 hidden">
    <div class="flex items-center justify-between mb-6">
      <h2 id="results-title" class="text-xl font-semibold text-text"></h2>
      <button id="clear-results" class="text-brand-600 hover:text-brand-700 underline text-sm">
        נקה חיפוש
      </button>
    </div>
    <div id="results-container"></div>
  </section>

  <!-- Loading state -->
  <div id="loading" class="hidden py-12 text-center">
    <div class="inline-block w-8 h-8 border-4 border-brand-200 border-t-brand-500 rounded-full animate-spin"></div>
    <p class="mt-4 text-muted">מחפש...</p>
  </div>

  <!-- Categories -->
  <section id="categories-section" class="py-8 md:py-12">
    <h2 class="text-2xl font-bold mb-6 text-text">קטגוריות פופולריות</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {categories.map((cat) => (
        <a
          href={`/category/${cat.slug}`}
          class="group p-4 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-md hover:shadow-brand-500/10 transition-all flex items-center justify-between"
        >
          <span class="font-medium group-hover:text-brand-600 transition-colors">{cat.name}</span>
          <span class="text-sm text-muted bg-brand-50 px-2 py-0.5 rounded-full">{cat.count.toLocaleString('he-IL')}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Popular Definitions -->
  {popularDefs && popularDefs.length > 0 && (
    <section id="popular-section" class="py-8 md:py-12">
      <h2 class="text-2xl font-bold mb-6 text-text">הגדרות פופולריות</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
        {popularDefs.map((def) => (
          <a
            href={`/definition/${def.slug}`}
            class="group p-4 bg-surface border border-border rounded-xl text-center hover:border-brand-300 hover:shadow-md hover:shadow-brand-500/10 transition-all"
          >
            <span class="group-hover:text-brand-600 transition-colors">{def.definition_he}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Tips -->
  <section class="py-8 md:py-12 bg-brand-50 border border-brand-100 rounded-xl p-6 md:p-8">
    <h2 class="text-xl font-semibold mb-4 text-text">טיפים לחיפוש</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <h3 class="font-semibold mb-2 text-brand-700">חיפוש לפי הגדרה</h3>
        <ul class="space-y-2 text-muted text-sm">
          <li class="flex items-start gap-2">
            <span class="text-brand-500 mt-0.5">•</span>
            <span>הקלד את ההגדרה כמו שהיא מופיעה בתשבץ</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-500 mt-0.5">•</span>
            <span>ניתן לחפש גם חלק מהגדרה</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-500 mt-0.5">•</span>
            <span>אם לא מצאת - נסה מילה נרדפת להגדרה</span>
          </li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold mb-2 text-brand-700">חיפוש לפי תבנית</h3>
        <ul class="space-y-2 text-muted text-sm">
          <li class="flex items-start gap-2">
            <span class="text-brand-500 mt-0.5">•</span>
            <span>השתמש ב-<code class="bg-white px-1 rounded text-brand-600">?</code> עבור אות לא ידועה</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-500 mt-0.5">•</span>
            <span>לדוגמה: <code class="bg-white px-1 rounded text-brand-600">א?ב?ה</code> ימצא "אבובה", "אגבה"</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-500 mt-0.5">•</span>
            <span>ניתן לשלב עם מספר אותיות: <code class="bg-white px-1 rounded text-brand-600">א??ה 4 אותיות</code></span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="py-8 md:py-12">
    <h2 class="text-2xl font-bold mb-6 text-text">כלים נוספים</h2>
    <div class="grid md:grid-cols-3 gap-4">
      <a href="/synonyms" class="group p-6 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-semibold text-lg mb-2 group-hover:text-brand-600 transition-colors">מילים נרדפות</h3>
        <p class="text-sm text-muted">מצא מילה נרדפת מתוך מאגר של 56,000+ נרדפות</p>
      </a>
      <a href="/rhymes" class="group p-6 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-semibold text-lg mb-2 group-hover:text-brand-600 transition-colors">חרוזים</h3>
        <p class="text-sm text-muted">מצא חרוז לכל מילה - 40,000+ חרוזים</p>
      </a>
      <a href="/words" class="group p-6 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-semibold text-lg mb-2 group-hover:text-brand-600 transition-colors">מילים לפי אורך</h3>
        <p class="text-sm text-muted">רשימות מילים לפי מספר אותיות - לתשבצים ווורדל</p>
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const supabase = createClient(supabaseUrl, supabaseAnonKey);

  const form = document.getElementById('search-form') as HTMLFormElement;
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsSection = document.getElementById('results-section')!;
  const resultsTitle = document.getElementById('results-title')!;
  const resultsContainer = document.getElementById('results-container')!;
  const loading = document.getElementById('loading')!;
  const clearBtn = document.getElementById('clear-results')!;
  const categoriesSection = document.getElementById('categories-section')!;
  const popularSection = document.getElementById('popular-section');
  const letterCountBtns = document.querySelectorAll('.letter-count-btn');

  let activeLetterCount: number | null = null;

  function showResults() {
    resultsSection.classList.remove('hidden');
    categoriesSection.classList.add('hidden');
    if (popularSection) popularSection.classList.add('hidden');
  }

  function hideResults() {
    resultsSection.classList.add('hidden');
    categoriesSection.classList.remove('hidden');
    if (popularSection) popularSection.classList.remove('hidden');
    activeLetterCount = null;
    letterCountBtns.forEach(btn => {
      btn.classList.remove('bg-brand-500', 'text-white', 'border-brand-500');
      btn.classList.add('bg-surface', 'border-border');
    });
  }

  // Letter count filter buttons
  letterCountBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const count = parseInt(btn.getAttribute('data-letters') || '0');
      if (activeLetterCount === count) {
        activeLetterCount = null;
        btn.classList.remove('bg-brand-500', 'text-white', 'border-brand-500');
        btn.classList.add('bg-surface', 'border-border');
      } else {
        activeLetterCount = count;
        letterCountBtns.forEach(b => {
          b.classList.remove('bg-brand-500', 'text-white', 'border-brand-500');
          b.classList.add('bg-surface', 'border-border');
        });
        btn.classList.remove('bg-surface', 'border-border');
        btn.classList.add('bg-brand-500', 'text-white', 'border-brand-500');
      }
      // Re-run search if there's a query
      if (input.value.trim()) search(input.value);
    });
  });

  async function search(query: string) {
    if (!query.trim()) return;

    const url = new URL(window.location.href);
    url.searchParams.set('q', query);
    window.history.pushState({}, '', url);

    loading.classList.remove('hidden');
    categoriesSection.classList.add('hidden');
    if (popularSection) popularSection.classList.add('hidden');
    resultsSection.classList.add('hidden');

    try {
      let letterCount = activeLetterCount;
      let searchQuery = query.trim();

      const letterMatch = searchQuery.match(/(\d+)\s*אותיות/);
      if (letterMatch) {
        letterCount = parseInt(letterMatch[1]);
        searchQuery = searchQuery.replace(/\d+\s*אותיות/, '').trim();
      }

      const isPattern = searchQuery.includes('?');
      let results: any[] = [];

      if (isPattern) {
        const pattern = searchQuery.replace(/\?/g, '_');
        let q = supabase
          .from('crossword_solutions')
          .select(`
            solution,
            letter_count,
            crossword_definitions (slug, definition_he)
          `)
          .ilike('solution', pattern);

        if (letterCount) q = q.eq('letter_count', letterCount);
        const { data } = await q.limit(30);
        results = data || [];
      } else {
        const { data } = await supabase
          .from('crossword_definitions')
          .select(`
            slug,
            definition_he,
            crossword_solutions (solution, letter_count)
          `)
          .ilike('definition_he', `%${searchQuery}%`)
          .limit(50);

        if (letterCount && data) {
          results = data.map((def: any) => ({
            ...def,
            crossword_solutions: def.crossword_solutions?.filter(
              (s: any) => s.letter_count === letterCount
            )
          })).filter((def: any) => def.crossword_solutions?.length > 0);
        } else {
          results = data || [];
        }
      }

      loading.classList.add('hidden');
      showResults();
      const titleParts = [`תוצאות עבור "${searchQuery}"`];
      if (letterCount) titleParts.push(`${letterCount} אותיות`);
      titleParts.push(`(${results.length} נמצאו)`);
      resultsTitle.textContent = titleParts.join(' - ');

      if (results.length > 0) {
        if (isPattern) {
          resultsContainer.innerHTML = `
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
              ${results.map((sol: any) => `
                <a href="/definition/${sol.crossword_definitions?.slug || ''}"
                   class="group p-4 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-lg transition-all text-center">
                  <span class="text-2xl font-bold text-brand-600">${sol.solution}</span>
                  <p class="text-sm text-muted mt-2">${sol.crossword_definitions?.definition_he || ''}</p>
                </a>
              `).join('')}
            </div>
          `;
        } else {
          resultsContainer.innerHTML = `
            <div class="space-y-4">
              ${results.map((def: any) => `
                <a href="/definition/${def.slug}"
                   class="group block p-6 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-lg hover:shadow-brand-500/10 transition-all">
                  <h3 class="text-lg font-semibold text-text group-hover:text-brand-600 transition-colors">${def.definition_he}</h3>
                  ${def.crossword_solutions && def.crossword_solutions.length > 0 ? `
                    <div class="mt-3 flex flex-wrap gap-2">
                      ${def.crossword_solutions.slice(0, 5).map((sol: any) => `
                        <span class="px-3 py-1 bg-brand-50 text-brand-700 rounded-full text-sm">
                          ${sol.solution} (${sol.letter_count} אותיות)
                        </span>
                      `).join('')}
                      ${def.crossword_solutions.length > 5 ? `
                        <span class="px-3 py-1 text-muted text-sm">
                          +${def.crossword_solutions.length - 5} עוד
                        </span>
                      ` : ''}
                    </div>
                  ` : ''}
                </a>
              `).join('')}
            </div>
          `;
        }
      } else {
        resultsContainer.innerHTML = `
          <div class="bg-brand-50 rounded-xl p-8 text-center border border-brand-100">
            <p class="text-muted">לא נמצאו תוצאות עבור "${query}"</p>
            <p class="text-sm mt-2 text-muted">נסה לחפש מילה אחרת או בדוק את האיות</p>
          </div>
        `;
      }
    } catch (error) {
      console.error('Search error:', error);
      loading.classList.add('hidden');
      resultsSection.classList.remove('hidden');
      resultsTitle.textContent = 'שגיאה בחיפוש';
      resultsContainer.innerHTML = `
        <div class="bg-red-50 rounded-xl p-8 text-center border border-red-100">
          <p class="text-red-600">אירעה שגיאה בחיפוש. נסה שוב.</p>
        </div>
      `;
    }
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    search(input.value);
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    hideResults();
    window.history.pushState({}, '', '/solver');
  });

  const urlParams = new URLSearchParams(window.location.search);
  const initialQuery = urlParams.get('q');
  if (initialQuery) {
    input.value = initialQuery;
    search(initialQuery);
  }
</script>
