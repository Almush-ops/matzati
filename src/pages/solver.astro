---
import BaseLayout from '../layouts/BaseLayout.astro';
import { supabase } from '../lib/supabase';

const query = Astro.url.searchParams.get('q') || '';
let results: any[] = [];

if (query) {
  // Search in definitions
  const { data: definitions } = await supabase
    .from('crossword_definitions')
    .select(`
      slug,
      definition_he,
      crossword_solutions (solution, letter_count)
    `)
    .ilike('definition_he', `%${query}%`)
    .limit(20);

  results = definitions || [];
}
---

<BaseLayout title="פותר תשבצים אוטומטי" description="חפש פתרונות לתשבצים לפי הגדרה או תבנית אותיות">
  <section class="text-center py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-bold mb-4 text-text">פותר תשבצים אוטומטי</h1>
    <p class="text-muted mb-8">הקלד הגדרה או תבנית (לדוגמה: א?ב?ה)</p>

    <form action="/solver" method="get" class="max-w-2xl mx-auto">
      <div class="relative">
        <input
          type="search"
          name="q"
          value={query}
          placeholder="הקלד הגדרה..."
          class="w-full px-6 py-4 text-lg bg-surface border-2 border-border rounded-full focus:border-brand-500 focus:ring-4 focus:ring-brand-100 outline-none transition-all"
        />
        <button
          type="submit"
          class="absolute left-2 top-1/2 -translate-y-1/2 bg-accent-500 text-white px-6 py-3 rounded-full font-semibold hover:bg-accent-600 transition-colors shadow-md"
        >
          חפש
        </button>
      </div>
    </form>
  </section>

  {query && (
    <section class="py-8 md:py-12">
      <h2 class="text-xl font-semibold mb-6 text-text">
        תוצאות עבור "{query}" ({results.length} נמצאו)
      </h2>

      {results.length > 0 ? (
        <div class="space-y-4">
          {results.map((def) => (
            <a
              href={`/definition/${def.slug}`}
              class="group block p-6 bg-surface border border-border rounded-xl hover:border-brand-300 hover:shadow-lg hover:shadow-brand-500/10 transition-all"
            >
              <h3 class="text-lg font-semibold text-text group-hover:text-brand-600 transition-colors">{def.definition_he}</h3>
              {def.crossword_solutions && def.crossword_solutions.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {def.crossword_solutions.slice(0, 5).map((sol: any) => (
                    <span class="px-3 py-1 bg-brand-50 text-brand-700 rounded-full text-sm">
                      {sol.solution} ({sol.letter_count} אותיות)
                    </span>
                  ))}
                  {def.crossword_solutions.length > 5 && (
                    <span class="px-3 py-1 text-muted text-sm">
                      +{def.crossword_solutions.length - 5} עוד
                    </span>
                  )}
                </div>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="bg-brand-50 rounded-xl p-8 text-center border border-brand-100">
          <p class="text-muted">לא נמצאו תוצאות עבור "{query}"</p>
          <p class="text-sm mt-2 text-muted">נסה לחפש מילה אחרת או בדוק את האיות</p>
        </div>
      )}
    </section>
  )}

  <!-- Tips -->
  <section class="py-8 md:py-12 bg-brand-50 border border-brand-100 rounded-xl p-6 md:p-8 mt-8">
    <h2 class="text-xl font-semibold mb-4 text-text">טיפים לחיפוש</h2>
    <ul class="space-y-3 text-muted">
      <li class="flex items-start gap-2">
        <span class="text-brand-500">•</span>
        <span>הקלד את ההגדרה כמו שהיא מופיעה בתשבץ</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-brand-500">•</span>
        <span>לחיפוש לפי תבנית: השתמש ב-? עבור אות לא ידועה (לדוגמה: א?ב?ה)</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-brand-500">•</span>
        <span>אם לא מצאת - נסה מילה נרדפת להגדרה</span>
      </li>
    </ul>
  </section>
</BaseLayout>
