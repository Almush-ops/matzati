---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  // Generate paths for 2-15 letters
  return Array.from({ length: 14 }, (_, i) => ({
    params: { length: `${i + 2}-letters` },
  }));
}

const { length } = Astro.params;
const letterCount = parseInt(length.split('-')[0]);

// Fetch words with this length
const { data: words } = await supabase
  .from('hebrew_words')
  .select('*')
  .eq('letter_count', letterCount)
  .order('first_letter')
  .order('word');

// Group by first letter
const hebrewLetters = 'אבגדהוזחטיכלמנסעפצקרשת'.split('');
const wordsByLetter: Record<string, typeof words> = {};
hebrewLetters.forEach(letter => {
  wordsByLetter[letter] = words?.filter(w => w.first_letter === letter) || [];
});

const pageTitle = `מילים בנות ${letterCount} אותיות`;
const pageDescription = `רשימת ${words?.length || 0} מילים בעברית באורך ${letterCount} אותיות`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article>
    <nav class="text-sm text-text-muted mb-4">
      <a href="/" class="hover:text-primary">ראשי</a>
      <span class="mx-2">/</span>
      <a href="/words" class="hover:text-primary">מילים</a>
      <span class="mx-2">/</span>
      <span class="text-text">{letterCount} אותיות</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold mb-2">
      מילים בנות {letterCount} אותיות
    </h1>
    <p class="text-text-muted mb-8">
      {words?.length || 0} מילים נמצאו
    </p>

    <!-- Navigation to other lengths -->
    <div class="flex flex-wrap gap-2 mb-8">
      {[2, 3, 4, 5, 6, 7, 8, 9, 10].map((n) => (
        <a
          href={`/words/${n}-letters`}
          class:list={[
            "px-4 py-2 rounded-full transition-all",
            n === letterCount
              ? "bg-primary text-white"
              : "bg-gray-100 hover:bg-gray-200"
          ]}
        >
          {n} אותיות
        </a>
      ))}
    </div>

    <!-- Letter navigation -->
    <div class="flex flex-wrap gap-2 mb-8 sticky top-0 bg-background py-2 z-10">
      {hebrewLetters.map((letter) => (
        <a
          href={`#letter-${letter}`}
          class:list={[
            "w-10 h-10 flex items-center justify-center rounded-lg text-lg font-bold transition-all",
            wordsByLetter[letter]?.length > 0
              ? "bg-surface border border-gray-200 hover:border-primary"
              : "bg-gray-100 text-gray-400 cursor-not-allowed"
          ]}
        >
          {letter}
        </a>
      ))}
    </div>

    <!-- Words grouped by letter -->
    <div class="space-y-8">
      {hebrewLetters.map((letter) => (
        wordsByLetter[letter]?.length > 0 && (
          <section id={`letter-${letter}`} class="scroll-mt-16">
            <h2 class="text-2xl font-bold mb-4 flex items-center gap-2">
              <span class="w-10 h-10 bg-primary text-white rounded-lg flex items-center justify-center">
                {letter}
              </span>
              <span class="text-text-muted text-base font-normal">
                ({wordsByLetter[letter]?.length} מילים)
              </span>
            </h2>
            <div class="grid grid-cols-3 md:grid-cols-5 lg:grid-cols-8 gap-2">
              {wordsByLetter[letter]?.map((w) => (
                <span class="p-2 bg-surface border border-gray-200 rounded text-center text-sm">
                  {w.word}
                </span>
              ))}
            </div>
          </section>
        )
      ))}
    </div>
  </article>
</BaseLayout>
