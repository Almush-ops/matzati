---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

// Get unique words with synonyms
const { data: words } = await supabase
  .from('synonyms')
  .select('word')
  .limit(100);

const uniqueWords = [...new Set(words?.map(w => w.word) || [])];

// Group by first letter
const hebrewLetters = 'אבגדהוזחטיכלמנסעפצקרשת'.split('');
---

<BaseLayout title="מילים נרדפות בעברית" description="מילון מילים נרדפות בעברית - מצא סינונימים לכל מילה">
  <section class="text-center py-8">
    <h1 class="text-3xl md:text-4xl font-bold mb-4">מילים נרדפות בעברית</h1>
    <p class="text-text-muted mb-8">מצא מילה נרדפת לכל מילה בעברית</p>

    <form action="/synonyms" method="get" class="max-w-xl mx-auto mb-8">
      <div class="relative">
        <input
          type="search"
          name="q"
          placeholder="הקלד מילה..."
          class="w-full px-6 py-4 text-lg border-2 border-gray-300 rounded-full focus:border-primary outline-none"
        />
        <button
          type="submit"
          class="absolute left-2 top-1/2 -translate-y-1/2 bg-primary text-white px-6 py-2 rounded-full"
        >
          חפש
        </button>
      </div>
    </form>
  </section>

  <!-- Alphabetical Index -->
  <section class="py-8">
    <h2 class="text-2xl font-bold mb-6">חיפוש לפי אות</h2>
    <div class="flex flex-wrap gap-2 justify-center">
      {hebrewLetters.map((letter) => (
        <a
          href={`/synonyms?letter=${letter}`}
          class="w-12 h-12 flex items-center justify-center bg-surface border border-gray-200 rounded-lg text-xl font-bold hover:border-primary hover:bg-primary/5 transition-all"
        >
          {letter}
        </a>
      ))}
    </div>
  </section>

  <!-- Popular Words -->
  {uniqueWords.length > 0 && (
    <section class="py-8">
      <h2 class="text-2xl font-bold mb-6">מילים פופולריות</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">
        {uniqueWords.slice(0, 24).map((word) => (
          <a
            href={`/synonyms/${word}`}
            class="p-4 bg-surface border border-gray-200 rounded-lg text-center hover:border-primary transition-all"
          >
            {word}
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
