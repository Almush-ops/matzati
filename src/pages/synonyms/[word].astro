---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchAll } from '../../lib/fetchAll';
import { stripNikud } from '../../lib/stripNikud';

export async function getStaticPaths() {
  // Bulk fetch ALL synonyms
  const allSynonyms = await fetchAll('matzati_synonyms', 'word, synonym');
  console.log(`[synonyms] Fetched ${allSynonyms.length} synonym rows`);

  // Group by word
  const synByWord = new Map<string, string[]>();
  for (const s of allSynonyms) {
    if (!synByWord.has(s.word)) synByWord.set(s.word, []);
    synByWord.get(s.word)!.push(s.synonym);
  }

  // Build reverse map for "related words" (words that list this word as synonym)
  const reverseMap = new Map<string, string[]>();
  for (const s of allSynonyms) {
    if (!reverseMap.has(s.synonym)) reverseMap.set(s.synonym, []);
    reverseMap.get(s.synonym)!.push(s.word);
  }

  // Set of all valid words (words that have their own page)
  const validWords = new Set(synByWord.keys());

  const uniqueWords = [...synByWord.keys()];
  console.log(`[synonyms] ${uniqueWords.length} unique words`);

  // stripNikud helper inline (can't use import in getStaticPaths scope easily)
  const strip = (text: string) => text.replace(/[\u0591-\u05C7]/g, '');

  return uniqueWords.map((word) => {
    const allSyns = synByWord.get(word) || [];
    const allRelated = [...new Set(reverseMap.get(word) || [])].slice(0, 12);

    // Split synonyms into linked (have page) and plain (no page)
    const linkedSynonyms: string[] = [];
    const plainSynonyms: string[] = [];
    for (const syn of allSyns) {
      if (validWords.has(strip(syn))) {
        linkedSynonyms.push(syn);
      } else {
        plainSynonyms.push(syn);
      }
    }

    // Related words are already word-column values, so they always have pages
    // But filter to be safe
    const linkedRelated = allRelated.filter(w => validWords.has(strip(w)));

    return {
      params: { word },
      props: { linkedSynonyms, plainSynonyms, linkedRelated },
    };
  });
}

const { word } = Astro.params;
const { linkedSynonyms, plainSynonyms, linkedRelated } = Astro.props;
const totalSynonyms = (linkedSynonyms?.length || 0) + (plainSynonyms?.length || 0);

const pageTitle = `מילים נרדפות ל"${word}" | סינונימים בעברית`;
const pageDescription = `${totalSynonyms} מילים נרדפות למילה "${word}". גלה סינונימים ומילים קשורות לשימוש בכתיבה ותשבצים.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article>
    <nav class="text-sm text-muted mb-6">
      <a href="/" class="hover:text-brand-600 transition-colors">ראשי</a>
      <span class="mx-2 text-border">←</span>
      <a href="/synonyms" class="hover:text-brand-600 transition-colors">מילים נרדפות</a>
      <span class="mx-2 text-border">←</span>
      <span class="text-text">{word}</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold mb-3 text-text">
      מילים נרדפות ל"{word}"
    </h1>
    <p class="text-muted mb-8">
      {totalSynonyms} מילים נרדפות נמצאו
    </p>

    {totalSynonyms > 0 ? (
      <section class="bg-surface border border-border rounded-xl p-6 mb-8">
        <h2 class="text-xl font-semibold mb-4 text-text">מילים נרדפות</h2>
        <div class="flex flex-wrap gap-3">
          {linkedSynonyms.map((syn: string) => (
            <a
              href={`/synonyms/${stripNikud(syn)}`}
              class="px-4 py-2 bg-brand-100 text-brand-700 rounded-full hover:bg-brand-200 transition-all font-medium"
            >
              {syn}
            </a>
          ))}
          {plainSynonyms.map((syn: string) => (
            <span class="px-4 py-2 bg-brand-50 text-brand-600 rounded-full">
              {syn}
            </span>
          ))}
        </div>
      </section>
    ) : (
      <div class="bg-brand-50 border border-brand-100 rounded-xl p-8 text-center mb-8">
        <p class="text-muted">לא נמצאו מילים נרדפות למילה זו.</p>
      </div>
    )}

    {linkedRelated && linkedRelated.length > 0 && (
      <section class="bg-surface border border-border rounded-xl p-6">
        <h2 class="text-xl font-semibold mb-4 text-text">מילים קשורות</h2>
        <div class="flex flex-wrap gap-3">
          {linkedRelated.map((w: string) => (
            <a
              href={`/synonyms/${stripNikud(w)}`}
              class="px-4 py-2 bg-brand-50 text-brand-600 border border-brand-200 rounded-full hover:bg-brand-100 transition-all"
            >
              {w}
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
