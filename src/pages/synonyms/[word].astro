---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

// Helper: paginated fetch
async function fetchAll(table: string, select: string) {
  const all: any[] = [];
  const pageSize = 1000;
  let page = 0;
  while (true) {
    const { data } = await supabase.from(table).select(select).range(page * pageSize, (page + 1) * pageSize - 1);
    if (!data || data.length === 0) break;
    all.push(...data);
    if (data.length < pageSize) break;
    page++;
  }
  return all;
}

export async function getStaticPaths() {
  // Bulk fetch ALL synonyms
  const allSynonyms = await fetchAll('matzati_synonyms', 'word, synonym');
  console.log(`[synonyms] Fetched ${allSynonyms.length} synonym rows`);

  // Group by word
  const synByWord = new Map<string, string[]>();
  for (const s of allSynonyms) {
    if (!synByWord.has(s.word)) synByWord.set(s.word, []);
    synByWord.get(s.word)!.push(s.synonym);
  }

  // Build reverse map for "related words" (words that list this word as synonym)
  const reverseMap = new Map<string, string[]>();
  for (const s of allSynonyms) {
    if (!reverseMap.has(s.synonym)) reverseMap.set(s.synonym, []);
    reverseMap.get(s.synonym)!.push(s.word);
  }

  const uniqueWords = [...synByWord.keys()];
  console.log(`[synonyms] ${uniqueWords.length} unique words`);

  return uniqueWords.map((word) => ({
    params: { word },
    props: {
      synonyms: synByWord.get(word) || [],
      relatedWords: [...new Set(reverseMap.get(word) || [])].slice(0, 12),
    },
  }));
}

const { word } = Astro.params;
const { synonyms, relatedWords } = Astro.props;

const pageTitle = `מילים נרדפות ל"${word}" | סינונימים בעברית`;
const pageDescription = `${synonyms?.length || 0} מילים נרדפות למילה "${word}". גלה סינונימים ומילים קשורות לשימוש בכתיבה ותשבצים.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article>
    <nav class="text-sm text-muted mb-6">
      <a href="/" class="hover:text-brand-600 transition-colors">ראשי</a>
      <span class="mx-2 text-border">←</span>
      <a href="/synonyms" class="hover:text-brand-600 transition-colors">מילים נרדפות</a>
      <span class="mx-2 text-border">←</span>
      <span class="text-text">{word}</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold mb-3 text-text">
      מילים נרדפות ל"{word}"
    </h1>
    <p class="text-muted mb-8">
      {synonyms?.length || 0} מילים נרדפות נמצאו
    </p>

    {synonyms && synonyms.length > 0 ? (
      <section class="bg-surface border border-border rounded-xl p-6 mb-8">
        <h2 class="text-xl font-semibold mb-4 text-text">מילים נרדפות</h2>
        <div class="flex flex-wrap gap-3">
          {synonyms.map((syn: string) => (
            <a
              href={`/synonyms/${syn}`}
              class="px-4 py-2 bg-brand-100 text-brand-700 rounded-full hover:bg-brand-200 transition-all font-medium"
            >
              {syn}
            </a>
          ))}
        </div>
      </section>
    ) : (
      <div class="bg-brand-50 border border-brand-100 rounded-xl p-8 text-center mb-8">
        <p class="text-muted">לא נמצאו מילים נרדפות למילה זו.</p>
      </div>
    )}

    {relatedWords && relatedWords.length > 0 && (
      <section class="bg-surface border border-border rounded-xl p-6">
        <h2 class="text-xl font-semibold mb-4 text-text">מילים קשורות</h2>
        <div class="flex flex-wrap gap-3">
          {relatedWords.map((w: string) => (
            <a
              href={`/synonyms/${w}`}
              class="px-4 py-2 bg-brand-50 text-brand-600 border border-brand-200 rounded-full hover:bg-brand-100 transition-all"
            >
              {w}
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
