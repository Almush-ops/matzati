---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  const { data: synonyms } = await supabase
    .from('synonyms')
    .select('word');

  const uniqueWords = [...new Set(synonyms?.map(s => s.word) || [])];

  return uniqueWords.map((word) => ({
    params: { word },
  }));
}

const { word } = Astro.params;

// Fetch synonyms for this word
const { data: synonyms } = await supabase
  .from('synonyms')
  .select('*')
  .eq('word', word);

// Fetch antonyms (reverse lookup)
const { data: antonyms } = await supabase
  .from('synonyms')
  .select('word')
  .eq('synonym', word);

const pageTitle = `מילים נרדפות ל"${word}" | סינונימים בעברית`;
const pageDescription = `${synonyms?.length || 0} מילים נרדפות למילה "${word}". גלה סינונימים ומילים קשורות לשימוש בכתיבה ותשבצים.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article>
    <nav class="text-sm text-muted mb-6">
      <a href="/" class="hover:text-brand-600 transition-colors">ראשי</a>
      <span class="mx-2 text-border">←</span>
      <a href="/synonyms" class="hover:text-brand-600 transition-colors">מילים נרדפות</a>
      <span class="mx-2 text-border">←</span>
      <span class="text-text">{word}</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold mb-3 text-text">
      מילים נרדפות ל"{word}"
    </h1>
    <p class="text-muted mb-8">
      {synonyms?.length || 0} מילים נרדפות נמצאו
    </p>

    {synonyms && synonyms.length > 0 ? (
      <section class="bg-surface border border-border rounded-xl p-6 mb-8">
        <h2 class="text-xl font-semibold mb-4 text-text">מילים נרדפות</h2>
        <div class="flex flex-wrap gap-3">
          {synonyms.map((syn) => (
            <a
              href={`/synonyms/${syn.synonym}`}
              class="px-4 py-2 bg-brand-100 text-brand-700 rounded-full hover:bg-brand-200 transition-all font-medium"
            >
              {syn.synonym}
              {syn.relation_type === 'exact' && (
                <span class="text-xs mr-1 text-brand-500">(מדויק)</span>
              )}
            </a>
          ))}
        </div>
      </section>
    ) : (
      <div class="bg-brand-50 border border-brand-100 rounded-xl p-8 text-center mb-8">
        <p class="text-muted">לא נמצאו מילים נרדפות למילה זו.</p>
      </div>
    )}

    {antonyms && antonyms.length > 0 && (
      <section class="bg-surface border border-border rounded-xl p-6">
        <h2 class="text-xl font-semibold mb-4 text-text">מילים קשורות</h2>
        <div class="flex flex-wrap gap-3">
          {antonyms.map((ant) => (
            <a
              href={`/synonyms/${ant.word}`}
              class="px-4 py-2 bg-brand-50 text-brand-600 border border-brand-200 rounded-full hover:bg-brand-100 transition-all"
            >
              {ant.word}
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
