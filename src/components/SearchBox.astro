---
interface Props {
  placeholder?: string;
  action?: string;
}

const { placeholder = 'חפש הגדרה, מילה או חרוז...', action = '/solver' } = Astro.props;
---

<form action={action} method="get" class="w-full max-w-2xl mx-auto">
  <div class="relative">
    <input
      type="search"
      name="q"
      placeholder={placeholder}
      class="w-full px-6 py-4 text-lg bg-surface border-2 border-border rounded-full focus:border-brand-500 focus:ring-4 focus:ring-brand-100 outline-none transition-all"
    />
    <button
      type="submit"
      class="absolute left-2 top-1/2 -translate-y-1/2 bg-accent-500 text-gray-900 px-6 py-3 rounded-full font-semibold hover:bg-accent-600 transition-colors shadow-md hover:shadow-lg"
    >
      חפש
    </button>
  </div>
</form>
