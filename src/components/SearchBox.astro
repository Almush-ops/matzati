---
interface Props {
  placeholder?: string;
  action?: string;
}

const { placeholder = 'חפש הגדרה, מילה או חרוז...', action = '/solver' } = Astro.props;
---

<form action={action} method="get" class="w-full max-w-2xl mx-auto">
  <div class="relative">
    <input
      type="search"
      name="q"
      placeholder={placeholder}
      class="w-full px-6 py-4 text-lg border-2 border-gray-300 rounded-full focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
    />
    <button
      type="submit"
      class="absolute left-2 top-1/2 -translate-y-1/2 bg-primary text-white px-6 py-2 rounded-full hover:bg-primary-dark transition-colors"
    >
      חפש
    </button>
  </div>
</form>
