---
interface Props {
  slug: string;
  definition: string;
  solutionCount?: number;
}

const { slug, definition, solutionCount } = Astro.props;
---

<a
  href={`/definition/${slug}`}
  class="group block p-4 bg-surface border border-border rounded-lg hover:border-brand-300 hover:shadow-md hover:shadow-brand-500/10 transition-all"
>
  <h3 class="font-semibold text-lg text-text group-hover:text-brand-600 transition-colors">{definition}</h3>
  {solutionCount && (
    <p class="text-sm text-muted mt-1">{solutionCount} פתרונות</p>
  )}
</a>
