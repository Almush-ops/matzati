---
import '../styles/global.css';
import SchemaOrg from '../components/SchemaOrg.astro';

interface Props {
  title: string;
  description?: string;
  schema?: Record<string, any> | Record<string, any>[];
  noindex?: boolean;
}

const { title, description = 'מצאתי - פתרונות תשבצים, מילים נרדפות וחרוזים בעברית', schema, noindex = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site?.toString() || 'https://matzati.co.il';
const fullTitle = `${title} | מצאתי`;
const ogImage = `${siteUrl}/og-image.svg`;

// Default WebSite schema
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'מצאתי',
  url: siteUrl,
  description: 'מאגר פתרונות תשבצים, מילים נרדפות וחרוזים בעברית',
  inLanguage: 'he',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/solver?q={search_term_string}`,
    'query-input': 'required name=search_term_string'
  }
};
---

<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="he_IL" />
    <meta property="og:site_name" content="מצאתי" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{fullTitle}</title>
    <SchemaOrg schema={websiteSchema} />
    {schema && <SchemaOrg schema={schema} />}
  </head>
  <body class="bg-background text-text min-h-screen font-sans flex flex-col">
    <header class="bg-surface border-b border-border sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity">
          <img src="/favicon.svg" alt="" width="32" height="32" class="w-8 h-8" />
          <span class="text-2xl font-bold text-brand-600">מצאתי</span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex gap-6">
          <a href="/solver" class="text-text hover:text-brand-600 transition-colors">פותר תשבצים</a>
          <a href="/synonyms" class="text-text hover:text-brand-600 transition-colors">מילים נרדפות</a>
          <a href="/rhymes" class="text-text hover:text-brand-600 transition-colors">חרוזים</a>
          <a href="/words" class="text-text hover:text-brand-600 transition-colors">מילים</a>
        </div>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-text hover:text-brand-600 transition-colors" aria-label="תפריט">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </nav>

      <!-- Mobile nav -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface">
        <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col gap-4">
          <a href="/solver" class="text-text hover:text-brand-600 transition-colors py-2">פותר תשבצים</a>
          <a href="/synonyms" class="text-text hover:text-brand-600 transition-colors py-2">מילים נרדפות</a>
          <a href="/rhymes" class="text-text hover:text-brand-600 transition-colors py-2">חרוזים</a>
          <a href="/words" class="text-text hover:text-brand-600 transition-colors py-2">מילים</a>
        </div>
      </div>
    </header>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>

    <main class="max-w-6xl mx-auto px-4 py-8">
      <slot />
    </main>

    <footer class="bg-surface border-t border-border mt-auto">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <!-- Footer nav -->
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-6">
          <a href="/solver" class="text-muted hover:text-brand-600 transition-colors">פותר תשבצים</a>
          <a href="/synonyms" class="text-muted hover:text-brand-600 transition-colors">מילים נרדפות</a>
          <a href="/rhymes" class="text-muted hover:text-brand-600 transition-colors">חרוזים</a>
          <a href="/words" class="text-muted hover:text-brand-600 transition-colors">מילים</a>
        </div>

        <!-- Legal links -->
        <div class="flex flex-wrap justify-center gap-x-4 gap-y-2 text-sm mb-4">
          <a href="/terms" class="text-muted hover:text-brand-600 transition-colors">תנאי שימוש</a>
          <span class="text-border">|</span>
          <a href="/privacy" class="text-muted hover:text-brand-600 transition-colors">מדיניות פרטיות</a>
          <span class="text-border">|</span>
          <a href="/accessibility" class="text-muted hover:text-brand-600 transition-colors">הצהרת נגישות</a>
        </div>

        <!-- Copyright -->
        <p class="text-center text-muted text-sm">
          &copy; {new Date().getFullYear()} מצאתי - פתרונות תשבצים בעברית
        </p>
      </div>
    </footer>
  </body>
</html>
